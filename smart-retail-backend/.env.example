# ============================================================
#  Smart Retail Platform — Environment Configuration Template
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_NAME=Smart Retail Analytics API
APP_VERSION=2.0.0
# Options: development | staging | production
APP_ENV=development
LOG_LEVEL=INFO

# ── JWT Authentication ────────────────────────────────────────
# REQUIRED: Generate a strong secret — min 32 random characters
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_use_a_strong_random_secret_min_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ──────────────────────────────────────────────────
# SQLite (default — suitable for development)
DATABASE_URL=sqlite:///./supply_chain.db

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql://username:password@localhost:5432/smart_retail

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Development default includes Vite (5173) and CRA (3000)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Rate Limiting ─────────────────────────────────────────────
# Max requests per minute per IP address
RATE_LIMIT_PER_MINUTE=120
