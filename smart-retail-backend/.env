# Database Configuration
DATABASE_URL=sqlite:///./supply_chain.db

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# ── JWT Authentication ────────────────────────────────────────────────────────
# IMPORTANT: Replace JWT_SECRET_KEY with a strong random value before deploying.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=smart-retail-super-secret-jwt-key-change-in-production-32chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# SLA Thresholds (in hours)
PROCUREMENT_SLA=48
PROCESSING_SLA=24
DISPATCH_SLA=12
DELIVERY_SLA=72
TOTAL_SLA=156